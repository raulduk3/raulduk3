{
   "action": {
      "browser_style": true,
      "default_icon": {
         "16": "icons/16.png",
         "32": "icons/32.png",
         "64": "icons/64.png"
      },
      "default_title": "Chrometana Pro"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "description": "Force Windows 10 and Cortana to use Google Chrome and your favorite search engine instead of Bing!",
   "host_permissions": [ "*://*.bing.com/*" ],
   "icons": {
      "128": "icons/128.png",
      "16": "icons/16.png",
      "32": "icons/32.png",
      "64": "icons/64.png"
   },
   "key": "",
   "manifest_version": 3,
   "minimum_chrome_version": "101",
   "name": "Chrometana Pro - Redirect Cortana and Bing",
   "options_ui": {
      "open_in_tab": true,
      "page": "options.html"
   },
   "permissions": [ "storage", "declarativeNetRequest" ],
   "short_name": "Chrometana Pro",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.3.0"
}
